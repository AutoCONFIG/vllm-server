# =============================================================================
# vLLM Engine Server Docker环境变量配置
# =============================================================================
# 复制此文件为 .env 并修改实际值
# =============================================================================

# -----------------------------------------------------------------------------
# Docker构建配置
# -----------------------------------------------------------------------------
CUDA_VERSION=12.9.1
PYTHON_VERSION=3.12
VLLM_VERSION=
FLASHINFER_VERSION=0.6.6

# -----------------------------------------------------------------------------
# 模型配置 (必需)
# -----------------------------------------------------------------------------
# 模型路径 - 请修改为实际路径
MODEL_PATH=/path/to/your/model

# -----------------------------------------------------------------------------
# 服务配置
# -----------------------------------------------------------------------------
HOST_PORT=8000

# -----------------------------------------------------------------------------
# Engine配置
# -----------------------------------------------------------------------------
GPU_MEMORY_UTILIZATION=0.95
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=64

# -----------------------------------------------------------------------------
# 多卡并行配置
# -----------------------------------------------------------------------------
# 张量并行大小 (每个节点的GPU数)
TENSOR_PARALLEL_SIZE=1
# 流水线并行大小 (节点数)
PIPELINE_PARALLEL_SIZE=1
# 分布式执行后端: mp 或 ray
DISTRIBUTED_EXECUTOR_BACKEND=mp

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_REQUESTS=false

# -----------------------------------------------------------------------------
# HuggingFace配置
# -----------------------------------------------------------------------------
# HuggingFace Token (用于下载私有模型)
HF_TOKEN=

# -----------------------------------------------------------------------------
# Docker配置
# -----------------------------------------------------------------------------
# 共享内存大小 (对于多卡并行很重要)
SHM_SIZE=8gb
